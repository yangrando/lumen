<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>AI_BASE_URL</key>
	<string>$(AI_BASE_URL)</string>
	<key>GOOGLE_CALLBACK_SCHEME</key>
	<string>$(GOOGLE_CALLBACK_SCHEME)</string>
	<key>GOOGLE_CLIENT_ID</key>
	<string>$(GOOGLE_CLIENT_ID)</string>
	<key>GOOGLE_REDIRECT_URI</key>
	<string>$(GOOGLE_REDIRECT_URI)</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>$(GOOGLE_CALLBACK_SCHEME)</string>
			</array>
		</dict>
	</array>
	<key>UIAppFonts</key>
	<array>
		<string>SplineSans-Regular.ttf</string>
		<string>SplineSans-Bold.ttf</string>
		<string>SplineSans-SemiBold.ttf</string>
		<string>SplineSans-Medium.ttf</string>
		<string>SplineSans-Light.ttf</string>
	</array>
	<key>NSMicrophoneUsageDescription</key>
	<string>Lumen uses the microphone so you can ask AI questions with your voice.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>Lumen uses speech recognition to convert your voice questions into text.</string>
</dict>
</plist>
